{
  "project_name": "Project Name",
  "project_slug": "{{ cookiecutter.project_name | slugify | replace('_', '-') }}",
  "license": [
    "AGPL-3.0-only",
    "AGPL-3.0-or-later",
    "GPL-3.0-only",
    "GPL-3.0-or-later",
    "LGPL-3.0-only",
    "LGPL-3.0-or-later",
    "Apache-2.0",
    "BSD-3-Clause",
    "MIT",
    "Unlicense"
  ],
  "use_reuse": true,
  "author_name": "winston",
  "author_email": "hey@winston.sh",
  "repo_url": "https://code.winston.sh/winston/{{ cookiecutter.project_slug }}",
  "is_executable": true,
  "is_library": true,
  "__year": "{% now 'utc', '%Y' %}",
  "__author_name_email": "{{ cookiecutter.author_name }} <{{ cookiecutter.author_email }}>",
  "__spdx_text": "{{ cookiecutter.__year }} {{ cookiecutter.__author_name_email }}"
}
